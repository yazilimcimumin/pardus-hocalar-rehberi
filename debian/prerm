#!/bin/bash
# Kaldırma öncesi script
# Ottoman Techs - Teknofest 2026

set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Çalışan uygulamayı durdur
        if pgrep -f "pardus-yol-arkadasi" > /dev/null; then
            pkill -f "pardus-yol-arkadasi" || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
